# Google OAuth client secret file downloaded from Google Cloud Console.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Local OAuth token cache. Do not commit this file.
GOOGLE_TOKEN_FILE=token.json

# Optional default Google Sheet ID. You can also pass --sheet-id in the CLI.
GOOGLE_SHEET_ID=

# Local processed email log used for duplicate prevention.
PROCESSED_LOG_FILE=processed_emails.csv

# Sample mode output file.
OUTPUT_CSV_FILE=output_action_list.csv

# Local Ollama settings for appointment-only classification.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b
